# Local-dev only. The Vite dev server reads this key (NON-VITE_ prefix on purpose,
# so it is never bundled into client code) and injects it as the x-api-key header
# on requests proxied to api.anthropic.com.
#
# Copy this file to .env and fill in your key:  cp .env.example .env
ANTHROPIC_API_KEY=

# Optional, dev-only. Set to 1 ONLY if you develop behind a TLS-intercepting proxy
# (corporate MITM) and the dev server can't verify api.anthropic.com's certificate
# (502 "unable to verify the first certificate"). Leave unset/0 normally.
ANTHROPIC_PROXY_INSECURE_TLS=0
