{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "code-auditor report",
  "type": "object",
  "required": ["range", "spec_used", "findings"],
  "properties": {
    "range": { "type": "string" },
    "spec_used": { "type": ["string", "null"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["axis", "severity", "confidence", "file", "title", "detail"],
        "properties": {
          "axis": { "enum": ["improvement", "flaw", "spec-fit", "meta"] },
          "severity": { "enum": ["high", "medium", "low"] },
          "confidence": { "enum": ["high", "medium", "unverifiable"] },
          "file": { "type": "string" },
          "line": { "type": ["integer", "null"] },
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "suggestion": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
