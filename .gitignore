# ── Secrets (never commit) ─────────────────────────────────────────────────────
.env

# ── Model weights (never commit) ──────────────────────────────────────────────
*.gguf
*.ggml
*.bin
*.safetensors
blobs/

# ── Ollama local model cache (if repo is ever cloned inside ~/.ollama) ─────────
# The actual cache lives in ~/.ollama on the host — never symlink it here.

# ── Setup script local state ───────────────────────────────────────────────────
# Stores SHA256 hashes of built Modelfiles; regenerated by scripts/setup_models.py
Viper/scripts/.model_hashes.json

# ── Vector store ───────────────────────────────────────────────────────────────
Viper/data/chroma_db/

# ── Python artifacts ───────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Editor / OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Node / frontend (Vite + React) ─────────────────────────────────────────────
node_modules/
*.local
# (.env and dist/ are already ignored above)
