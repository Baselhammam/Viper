# Viper general-purpose LLM variant.
#
# Base: Mistral 7B Instruct v0.3, 4-bit K-means quantized.
# Pinned to a specific version tag (not :latest) so builds are reproducible.
# To use a SHA256 digest for true immutability, replace the FROM line with:
#   FROM mistral:7b-instruct-v0.3-q4_K_M@sha256:<digest>
#
# VRAM budget (RTX 5070, 12 GB):
#   Model weights  ~4.5 GB
#   KV cache 4096  ~0.5–1.0 GB
#   Total          ~5–5.5 GB  ✓ (safe with one model loaded at a time)
#
# num_ctx > 8192 approaches ~6–7 GB; num_ctx > 16384 may exhaust 12 GB.
#
# Build:  python scripts/setup_models.py
# Use:    set llm.model: "viper-llm" in config.yaml

FROM mistral:7b-instruct-v0.3-q4_K_M

SYSTEM """
You are Viper, a helpful local AI assistant. Answer questions accurately and
concisely. Use only information provided to you — do not fabricate facts.
When you are uncertain, say so clearly.
"""

PARAMETER temperature    0.7
PARAMETER num_ctx        4096
PARAMETER repeat_penalty 1.1
PARAMETER num_predict    512
