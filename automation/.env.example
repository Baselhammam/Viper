# Copy this file to `.env` (same folder or repo root) and fill in real values.
# `.env` is gitignored. NEVER commit real keys.

# Claude (Anthropic) API key — required to generate the report.
ANTHROPIC_API_KEY=

# Slack Incoming Webhook URL — where the report is POSTed (live mode only).
# Leave EMPTY locally to force dry-run (prints to stdout, posts nothing).
SLACK_WEBHOOK_URL=

# Slack bot token (xoxb-...) with channels:history — used to READ the channel.
SLACK_BOT_TOKEN=

# Slack channel ID (e.g. C0123456789) to read history from and post to.
SLACK_CHANNEL_ID=

# Notion internal integration token (ntn_... / secret_...).
NOTION_TOKEN=

# Notion page ID holding the to-do tasks.
NOTION_TASKS_PAGE_ID=3834c206-e250-8122-adc7-e04d155679d3
